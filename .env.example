# Required
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional — defaults shown
PORT=8080
DATA_DIR=.slice/data
MAX_WORKERS=3
SEED_DEMO=false

# Model overrides (any OpenRouter model ID)
DIRECTOR_MODEL=anthropic/claude-sonnet-4
WORKER_MODEL=anthropic/claude-sonnet-4
STEWARD_MODEL=anthropic/claude-haiku

# Auth (auto-generated if not set)
# AUTH_TOKEN=your-token-here

# Federation (comma-separated peer URLs)
# FEDERATION_PEERS=http://localhost:8081,http://localhost:8082
