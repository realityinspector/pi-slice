{
  "name": "@slice/storage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SQLite storage layer for Slice with multi-runtime support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./bun": {
      "types": "./src/bun-backend.ts",
      "import": "./dist/bun-backend.js",
      "default": "./dist/bun-backend.js"
    },
    "./node": {
      "types": "./src/node-backend.ts",
      "import": "./dist/node-backend.js",
      "default": "./dist/node-backend.js"
    },
    "./browser": {
      "types": "./src/browser-backend.ts",
      "import": "./dist/browser-backend.js",
      "default": "./dist/browser-backend.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@slice/core": "workspace:*"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.9",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.8.1",
    "sql.js": "^1.12.0"
  }
}
