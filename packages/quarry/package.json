{
  "name": "@slice/quarry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Core SDK for Slice - API, services, sync, and CLI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sf": "./dist/bin/sf.js",
    "slice": "./dist/bin/sf.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./src/api/index.ts",
      "import": "./dist/api/index.js",
      "default": "./dist/api/index.js"
    },
    "./services": {
      "types": "./src/services/index.ts",
      "import": "./dist/services/index.js",
      "default": "./dist/services/index.js"
    },
    "./sync": {
      "types": "./src/sync/index.ts",
      "import": "./dist/sync/index.js",
      "default": "./dist/sync/index.js"
    },
    "./cli": {
      "types": "./src/cli/index.ts",
      "import": "./dist/cli/index.js",
      "default": "./dist/cli/index.js"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "import": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    },
    "./http": {
      "types": "./src/http/index.ts",
      "import": "./dist/http/index.js",
      "default": "./dist/http/index.js"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./external-sync": {
      "types": "./src/external-sync/index.ts",
      "import": "./dist/external-sync/index.js",
      "default": "./dist/external-sync/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@slice/core": "workspace:*",
    "@slice/shared-routes": "workspace:*",
    "@slice/storage": "workspace:*",
    "hono": "^4.7.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0"
  }
}
